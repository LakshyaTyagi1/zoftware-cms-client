---
import CatalogProductCard from "../../../components/CatalogProductCard.astro";
import CatalogShell from "../../../components/CatalogShell.astro";
import catalog from "../../../data/catalog/zoftware.json";
import {
  getParentCategory,
  getProduct,
  getProductInitials,
  getLocalProductLogo,
  getProducts,
  getRating,
  getReviewCount,
  getSubcategory,
} from "../../../lib/catalog";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return catalog.products.map((product) => ({
    params: { slug: product.weburl },
  }));
}

const { slug } = Astro.params;
const product = getProduct(slug ?? "");

if (!product) {
  return Astro.redirect("/");
}

const parent = getParentCategory(product.parent_categories?.[0]?.weburl ?? "");
const category = getSubcategory(product.category?.[0]?.weburl ?? "");
const alternatives = getProducts((parent?.products ?? []).filter((weburl) => weburl !== product.weburl));
const rating = getRating(product);
const reviews = getReviewCount(product);
const logo = getLocalProductLogo(product);
const tabs = ["Overview", "Product Details", "Zoftware Analysis", "Features", "Reviews", "Pricing", "Alternatives", "Technology Stack"];
const ratingRows = [
  ["Ease of Use", product.ratings?.ease_of_use],
  ["Features", product.ratings?.breadth_of_features],
  ["Implementation", product.ratings?.ease_of_implementation],
  ["Value", product.ratings?.value_for_money],
  ["Support", product.ratings?.customer_support],
];
---

<BaseLayout title={`${product.product_name} Overview`} description={product.overview || product.description}>
  <CatalogShell>
    <main class="product-page">
      <div class="page">
        <nav class="catalog-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span>›</span>
          {parent ? <a href={`/category/p/${parent.weburl}`}>{parent.name}</a> : null}
          <span>›</span>
          {category ? <a href={`/category/${category.weburl}`}>{category.name}</a> : null}
          <span>›</span>
          <span>{product.product_name}</span>
        </nav>

        <section class="product-hero-card">
          <div class="product-hero-card__brand">
            <span class="catalog-logo-box is-large">
              {logo ? (
                <img src={logo} alt={`${product.product_name} logo`} />
              ) : (
                <b>{getProductInitials(product.product_name)}</b>
              )}
            </span>
            <div>
              <h1>{product.product_name}</h1>
              <p class="product-rating">
                <span>{"★".repeat(Math.round(rating))}{"☆".repeat(5 - Math.round(rating))}</span>
                <b>{rating.toFixed(1)}</b>
                <small>({reviews.toLocaleString()} reviews)</small>
              </p>
              <p>
                <strong>Analyzed By Zoftware</strong>
                <span>•</span>
                Last Updated: 24th Feb 2026
              </p>
            </div>
          </div>
          <a href="/voice-bot">Talk to an Expert</a>
        </section>

        <nav class="product-tabs" aria-label="Product sections">
          {tabs.map((tab, index) => (
            <a class={index === 0 ? "is-active" : ""} href="#product-overview-content">{tab}</a>
          ))}
        </nav>

        <div class="product-content-grid">
          <section class="product-content" id="product-overview-content">
            <article class="product-panel">
              <h2>{product.product_name} Overview</h2>
              <p>{product.overview || product.description}</p>
              <p>{product.usp}</p>
            </article>

            <article class="product-panel">
              <h2>Best For</h2>
              <div class="product-tag-list">
                <span>{product.best_for || "Growing teams"}</span>
                {(product.keywords ?? []).map((keyword) => <span>{keyword}</span>)}
                {(product.languages ?? []).map((language) => <span>{language}</span>)}
              </div>
            </article>

            <article class="product-panel product-panel--ratings">
              <h2>Ratings Snapshot</h2>
              <div class="rating-grid">
                {ratingRows.map(([label, value]) => (
                  <div>
                    <span>{label}</span>
                    <b>{Number(value ?? rating).toFixed(1)}</b>
                    <i><em style={`width: ${Math.min(Number(value ?? rating), 5) * 20}%`} /></i>
                  </div>
                ))}
              </div>
            </article>
          </section>

          <aside class="product-side">
            <section>
              <h2>Alternatives</h2>
              <div class="product-side__links">
                <a class="is-active" href="#alternatives">Alternatives for Ease of Use</a>
                <a href="#alternatives">Alternatives for Value for Money</a>
                <a href="#alternatives">Alternatives for Variety of Features</a>
                <a href="#alternatives">Alternatives for Customer Support</a>
              </div>
            </section>
            <section>
              <h2>Categories Associated</h2>
              <a class="associated-category" href={`/category/${category?.weburl ?? ""}`}>
                {category?.name ?? "Software"}
                <span>›</span>
              </a>
            </section>
          </aside>
        </div>

        {alternatives.length > 0 ? (
          <section class="category-section product-alternatives" id="alternatives">
            <div class="category-section__header">
              <h2>Similar products</h2>
              <a href={`/category/${category?.weburl ?? ""}`}>View all</a>
            </div>
            <div class="catalog-product-list catalog-product-list--compact">
              {alternatives.map((alternative) => (
                <CatalogProductCard product={alternative} />
              ))}
            </div>
          </section>
        ) : null}
      </div>
    </main>
  </CatalogShell>
</BaseLayout>

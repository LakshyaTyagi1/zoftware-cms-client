---
import Hero from "../components/Hero";
import LandingSections from "../components/LandingSections";
import Topbar from "../components/Topbar";
import site from "../data/site/zoftware.json";
import theme from "../data/themes/zoftware.json";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Zoftware - Business Software Reviews, Comparisons & Integrators"
  description="Compare software, read verified reviews, explore categories, and find trusted system integrators for your business on Zoftware."
>
  <Topbar client:load site={site} theme={theme} />
  <main>
    <Hero client:load hero={site.hero} />
    <LandingSections sections={site.sections} />
  </main>
</BaseLayout>

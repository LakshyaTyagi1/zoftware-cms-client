---
import CatalogProductCard from "../../../components/CatalogProductCard.astro";
import CatalogShell from "../../../components/CatalogShell.astro";
import catalog from "../../../data/catalog/zoftware.json";
import {
  formatNumber,
  getParentCategory,
  getProducts,
} from "../../../lib/catalog";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return catalog.categories.map((category) => ({
    params: { slug: category.weburl },
  }));
}

const { slug } = Astro.params;
const category = getParentCategory(slug ?? "");

if (!category) {
  return Astro.redirect("/");
}

const featuredProducts = getProducts(category.products);
const description = category.description || category.meta_description;
---

<BaseLayout title={`${category.name} Software Categories`} description={description}>
  <CatalogShell>
    <main class="catalog-page catalog-page--parent">
      <div class="page catalog-page__grid">
        <section class="catalog-main">
          <nav class="catalog-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span>›</span>
            <span>{category.name}</span>
          </nav>

          <h1>{category.name}</h1>

          <section class="catalog-overview">
            <h2>What is {category.name}</h2>
            <p>
              <strong>{category.name} software</strong> {description}
              These tools help teams evaluate options, compare capabilities, and shortlist products with more confidence.
            </p>
            <button type="button">See More</button>
          </section>

          <section class="category-section" id="popular-subcategories">
            <div class="category-section__header">
              <h2>Popular {category.name} Categories</h2>
              <a href="/categories">Filter by industry</a>
            </div>
            <div class="subcategory-grid">
              {category.subcategories.map((subcategory) => (
                <a class="subcategory-tile" href={`/category/${subcategory.weburl}`}>
                  <span>
                    <strong>{subcategory.name}</strong>
                    <small>{subcategory.description}</small>
                  </span>
                  <i>›</i>
                </a>
              ))}
            </div>
          </section>

          <section class="category-section">
            <div class="category-section__header">
              <h2>Best products used by {category.name} professionals</h2>
              <a href={`/category/${category.subcategories[0]?.weburl ?? ""}`}>View All</a>
            </div>
            <div class="catalog-product-list catalog-product-list--compact">
              {featuredProducts.map((product) => (
                <CatalogProductCard product={product} />
              ))}
            </div>
          </section>
        </section>

        <aside class="catalog-aside">
          <section class="metric-card">
            <p>Monthly Category Searches</p>
            <strong>{formatNumber(category.monthly_searches)}</strong>
            <p>Interest Generated</p>
            <strong>{formatNumber(category.interest_generated)}</strong>
          </section>

          <section class="sidebar-list">
            <h2>{category.name}</h2>
            {category.subcategories.map((subcategory) => (
              <a href={`/category/${subcategory.weburl}`}>
                {subcategory.name}
                <span>›</span>
              </a>
            ))}
          </section>
        </aside>
      </div>
    </main>
  </CatalogShell>
</BaseLayout>

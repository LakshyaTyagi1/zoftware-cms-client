---
import CatalogProductCard from "../../components/CatalogProductCard.astro";
import CatalogShell from "../../components/CatalogShell.astro";
import catalog from "../../data/catalog/zoftware.json";
import {
  getParentCategory,
  getProducts,
  getSubcategory,
} from "../../lib/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return catalog.subcategories.map((subcategory) => ({
    params: { slug: subcategory.weburl },
  }));
}

const { slug } = Astro.params;
const subcategory = getSubcategory(slug ?? "");

if (!subcategory) {
  return Astro.redirect("/");
}

const parent = getParentCategory(subcategory.parent.weburl);
const products = getProducts(subcategory.products);
const suggestedProducts = products.length > 0 ? products : getProducts(parent?.products ?? []);
---

<BaseLayout title={`${subcategory.name} Products`} description={subcategory.meta_description}>
  <CatalogShell>
    <main class="catalog-page catalog-page--subcategory">
      <div class="page catalog-page__grid">
        <section class="catalog-main">
          <nav class="catalog-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span>›</span>
            <a href={`/category/p/${subcategory.parent.weburl}`}>{subcategory.parent.name}</a>
            <span>›</span>
            <span>{subcategory.name}</span>
          </nav>

          <p class="catalog-eyebrow">{subcategory.parent.name}</p>
          <h1>{subcategory.name}</h1>

          <section class="catalog-overview">
            <h2>What is {subcategory.name}</h2>
            <p>
              <strong>{subcategory.name}</strong> helps businesses manage related workflows,
              compare vendors, and choose tools with a clear view of pricing, support, and implementation fit.
            </p>
            <button type="button">See More</button>
          </section>

          <section class="compatibility-card">
            <div>
              <p>Check Compatibility for FREE, for accurate personalised results.</p>
              <h2>What is your monthly budget?</h2>
              <strong>$ 5000</strong>
            </div>
            <a href="/search/form">Next</a>
          </section>

          <section class="category-section">
            <div class="category-section__header category-section__header--filters">
              <h2>Products Available: {subcategory.product_count || suggestedProducts.length}</h2>
              <a href="/categories">Filter by industry</a>
            </div>
            <div class="catalog-filters">
              <button type="button">Rating</button>
              <button type="button">Segment</button>
              <button type="button">Alphabetical Order</button>
            </div>
            <div class="catalog-product-list">
              {suggestedProducts.map((product) => (
                <CatalogProductCard product={product} />
              ))}
            </div>
          </section>
        </section>

        <aside class="catalog-aside">
          <a class="buyer-guide-card" href={`/category/${subcategory.weburl}/buyers-guide`}>
            <small>Curious How to Purchase?</small>
            <strong>Explore Our Buyer's guide!</strong>
          </a>
          <section class="ad-placeholder" aria-label="Demo ad space" />
          <section class="ad-placeholder is-tall" aria-label="Demo ad space" />
        </aside>
      </div>
    </main>
  </CatalogShell>
</BaseLayout>

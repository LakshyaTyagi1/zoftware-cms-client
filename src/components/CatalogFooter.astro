---
import site from "../data/site/zoftware.json";
import { themes } from "../lib/themeEngine";

const logo = themes[0].assets.miniLogo;
---

<footer class="catalog-footer">
  <div class="page">
    <p class="catalog-footer__mission">
      Zoftware is on a mission to simplify technology buying for 100,000+ businesses.
    </p>
    <div class="catalog-footer__grid">
      <div>
        <h2>For Buyers</h2>
        <a href="/categories">Categories</a>
        <a href="/voice-bot">Consultation</a>
        <a href="/support">Support</a>
      </div>
      <div>
        <h2>For Vendors</h2>
        <a href="/vendors">List your product</a>
      </div>
      <div>
        <h2>Company</h2>
        <a href="/about">About</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms</a>
      </div>
      <div>
        <h2>Newsletter</h2>
        <p>Get updates and buyer playbooks straight to your inbox.</p>
        <form class="catalog-footer__form">
          <input type="email" placeholder="yourname@company.com" aria-label="Email address" />
          <button type="button">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="catalog-footer__bottom">
      <span>
        <img src={logo} alt="" />
        © 2026 {site.brand.name}. All rights reserved.
      </span>
      <span>English&nbsp;&nbsp;&nbsp; عربي</span>
    </div>
    <small>We're outcome-focused. Assistance fees apply only when results are delivered.</small>
  </div>
</footer>
